generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  image       String?  @db.LongText
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Matriz {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?  @db.Text
  image       String?  @db.LongText
  created_at  DateTime @default(now())
  samples     Sample[]

  @@map("matrizes")
}

model Sample {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(255)
  description String?           @db.Text
  image       String?           @db.LongText
  created_at  DateTime          @default(now())
  matriz      Matriz?           @relation(fields: [matrizId], references: [id], onDelete: SetNull)
  matrizId    Int?
  substances  SampleSubstance[]

  @@map("samples")
}

model SampleSubstance {
  id          Int       @id @default(autoincrement())
  sample      Sample    @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  sampleId    Int
  substance   Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  substanceId Int
  relativeArea Float?   @db.Float
  extraNote    String?  @db.Text

  @@unique([sampleId, substanceId])
  @@map("samples_substances")
}

model Substance {
  id               Int               @id @default(autoincrement())
  nist             Float             @db.Float
  tR               Float             @db.Float
  name             String            @db.VarChar(255)
  class            String            @db.VarChar(100)
  smiles           String?            @db.VarChar(255)
  molecularFormula String            @db.VarChar(50)
  molecularWeight  Float             @db.Float
  ionBase          BaseIon?
  otherIons        FragmentIon[]
  samples          SampleSubstance[]

  @@map("substances")
}

model BaseIon {
  id          Int       @id @default(autoincrement())
  mz          Int
  intensity   Float     @db.Float
  substance   Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  substanceId Int       @unique

  @@map("base_ions")
}

model FragmentIon {
  id          Int       @id @default(autoincrement())
  mz          Int
  intensity   Float     @db.Float
  substance   Substance @relation(fields: [substanceId], references: [id], onDelete: Cascade)
  substanceId Int

  @@map("fragment_ions")
}